{{- $kooldotsOnly := list
  ".config/ags/"
  ".config/ags/**"
}}

{{- $illogicalOnly := list
  ".config/quickshell/"
  ".config/quickshell/**"
  ".config/illogical-impulse/"
  ".config/illogical-impulse/**"
}}

{{- $hyprBase := list
  ".config/hypr/"
  ".config/hypr/**"
  ".config/waybar/"
  ".config/waybar/**"
  ".config/hyprpaper/"
  ".config/hyprpaper/**"
  ".config/hypridle/"
  ".config/hypridle/**"
  ".config/hyprlock/"
  ".config/hyprlock/**"
  ".config/zshrc.d/auto-Hypr.sh"
  ".config/zshrc.d/dots-hyprland.zsh"
  ".config/bashrc.d/auto-Hypr.sh"
}}

{{- $hyprAll := concat $hyprBase $kooldotsOnly $illogicalOnly }}

{{- if ne .desktop_profile "hyprland" }}
{{- range $hyprAll }}
{{ . }}
{{- end }}
{{- else }}

{{- if ne .hypr_profile "kooldots" }}
{{- range $kooldotsOnly }}
{{ . }}
{{- end }}
{{- end }}

{{- if ne .hypr_profile "illogical-impulse" }}
{{- range $illogicalOnly }}
{{ . }}
{{- end }}
{{- end }}

{{- end }}

{{- $zshOnly := list
  ".config/zshrc.d/"
  ".config/zshrc.d/**"
  ".zshrc"
}}

{{- $bashOnly := list
  ".config/bashrc.d/"
  ".config/bashrc.d/**"
  ".bashrc"
}}

{{- if not (has "zsh" .shells) }}
{{- range $zshOnly }}
{{ . }}
{{- end }}
{{- end }}

{{- if not (has "bash" .shells) }}
{{- range $bashOnly }}
{{ . }}
{{- end }}
{{- end }}


.config/packages
